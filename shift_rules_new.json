{
  "meta": {
    "name": "shift_notation_interpreter",
    "domain": "shift",
    "version": "1.2.0",
    "language": "ja-JP",
    "timezone": "Asia/Tokyo"
  },
  "objective": {
    "goal": "シフト記載の表記揺れを正規化し、勤務/休み/ヘルプ/複合移動/番手タグ/通し出勤を機械的に解釈して構造化する",
    "non_goals": [
      "休憩時間の自動推測",
      "店舗CDや店舗名の推測（store_master参照でのみ解決）",
      "番手時刻の推測（shift_time_master参照でのみ補完）"
    ]
  },
  "io": {
    "input": {
      "type": "object",
      "fields": [
        {
          "name": "raw_text",
          "type": "string",
          "required": true
        },
        {
          "name": "context",
          "type": "object",
          "required": false,
          "fields": [
            {
              "name": "home_store",
              "type": "string",
              "required": false
            },
            {
              "name": "home_store_cd",
              "type": "number",
              "required": false
            },
            {
              "name": "staff_type",
              "type": "string",
              "required": false,
              "enum": [
                "store_staff",
                "hq_staff",
                "unknown"
              ]
            }
          ]
        }
      ]
    },
    "output": {
      "type": "object",
      "schema": {
        "normalized_text": "string",
        "labels": "array",
        "entities": {
          "home_store": "string|null",
          "help_store": "string|null",
          "home_store_cd": "number|null",
          "help_store_cd": "number|null",
          "shift_type": "early|middle|late|null",
          "shift_tags": "array",
          "start_time": "HH:MM|null",
          "end_time": "HH:MM|null",
          "is_until_last": "boolean",
          "leave_type": "off_day|paid_leave|requested_off|null",
          "segments": "array"
        },
        "confidence": "number",
        "errors": "array"
      }
    }
  },
  "constraints": {
    "must": [
      "正規化（全半角、Unicode、区切り記号）を先に行う",
      "例外（休み・有給・希望休）を最優先で確定する",
      "複合移動（複数セグメント）を時間単体より優先して解釈する",
      "店舗表記が無い場合は所属店舗（context.home_store/home_store_cd）勤務として確定する",
      "番手記号＋片側時刻（例：◯-17:00）は解釈対象とし、欠けている時刻は外部の店舗別出勤時間マスタで補完する",
      "通し出勤（◯-✖️）は外部マスタから early.start と late.end を参照して確定する",
      "店舗CD付与はstore_master参照で行い、推測しない",
      "曖昧な場合はerrorsに理由を入れ、confidenceを下げる"
    ],
    "must_not": [
      "根拠なく時刻や店舗名を補完しない",
      "解釈不能な文字列を無理に勤務扱いにしない"
    ],
    "priority_order": [
      "exceptions",
      "canonicalize",
      "multi_segment",
      "two_segment_mixed",
      "store_time_range",
      "shift_tagged_time_range",
      "partial_time",
      "through_shift",
      "time_range",
      "time_until_last",
      "shift_symbol",
      "fallback",
      "postprocess_store_resolution"
    ]
  },
  "definitions": {
    "canonicalization": {
      "unicode_normalize": "NFKC",
      "trim": true,
      "collapse_spaces": true,
      "normalize_separators": {
        "from": [
          "〜",
          "～",
          "~",
          "－",
          "ー",
          "―",
          "‐",
          "–",
          "—",
          "−",
          "ｰ"
        ],
        "to": "-"
      }
    },
    "tokens": {
      "leave": {
        "off_day": [
          "公休"
        ],
        "paid_leave": [
          "有給"
        ],
        "requested_off": [
          "/",
          "／"
        ]
      },
      "shift_symbol_map": [
        {
          "canonical": "〇",
          "shift_type": "early",
          "aliases": [
            "〇",
            "○",
            "◯",
            "O",
            "o",
            "?"
          ]
        },
        {
          "canonical": "△",
          "shift_type": "middle",
          "aliases": [
            "△",
            "▲",
            "?"
          ]
        },
        {
          "canonical": "✕",
          "shift_type": "late",
          "aliases": [
            "✕",
            "×",
            "✗",
            "X",
            "x",
            "?",
            "??"
          ]
        }
      ]
    }
  },
  "rules": [
    {
      "id": "E-001",
      "kind": "exception",
      "name": "未記入は休み",
      "priority": 1000,
      "when": {
        "is_empty_or_whitespace": true
      },
      "then": {
        "set": {
          "entities.leave_type": "off_day",
          "entities.is_until_last": false
        },
        "labels_add": [
          "leave"
        ],
        "normalize": {
          "normalized_text": ""
        },
        "confidence": 0.95
      }
    },
    {
      "id": "E-002",
      "kind": "exception",
      "name": "公休/有給/希望休の確定",
      "priority": 990,
      "when": {
        "any_of": [
          {
            "contains_any": [
              "公休"
            ]
          },
          {
            "contains_any": [
              "有給"
            ]
          },
          {
            "equals_any": [
              "/",
              "／"
            ]
          }
        ]
      },
      "then": {
        "set_from_match": [
          {
            "if_contains": "公休",
            "set": {
              "entities.leave_type": "off_day"
            }
          },
          {
            "if_contains": "有給",
            "set": {
              "entities.leave_type": "paid_leave"
            }
          },
          {
            "if_equals_any": [
              "/",
              "／"
            ],
            "set": {
              "entities.leave_type": "requested_off"
            }
          }
        ],
        "labels_add": [
          "leave"
        ],
        "confidence": 0.98
      }
    },
    {
      "id": "R-100",
      "kind": "rule",
      "name": "正規化前処理（NFKC・区切り統一・空白圧縮）",
      "priority": 900,
      "when": {
        "always": true
      },
      "then": {
        "normalize_text_pipeline": [
          "unicode_nfkc",
          "trim",
          "collapse_spaces",
          "normalize_separators"
        ]
      }
    },
    {
      "id": "R-431",
      "kind": "rule",
      "name": "複数セグメント候補（店舗+時間が複数回登場）",
      "priority": 830,
      "when": {
        "regex": "^(?:[\\p{L}\\p{N}ぁ-んァ-ヶ一-龠々・]{1,12}\\s*(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?\\s*-\\s*(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?){2,}$"
      },
      "then": {
        "labels_add": [
          "multi_segment_compact"
        ],
        "confidence": 0.9
      }
    },
    {
      "id": "R-432",
      "kind": "rule",
      "name": "前半:時間帯(店舗なし) + 後半:店舗+時間帯（例：1100-14川崎1500-1800）",
      "priority": 825,
      "when": {
        "regex": "^(?<start1>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)\\s*-\\s*(?<end1>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)\\s*(?<store>[\\p{L}\\p{N}ぁ-んァ-ヶ一-龠々・]{1,12})\\s*(?<start2>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)\\s*-\\s*(?<end2>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)$"
      },
      "then": {
        "labels_add": [
          "two_segment_mixed"
        ],
        "set": {
          "entities.help_store": "{store}",
          "entities.is_until_last": false
        },
        "confidence": 0.9
      }
    },
    {
      "id": "R-430",
      "kind": "rule",
      "name": "店舗+時間帯：川崎11:00-17 / 川崎1100-17:00",
      "priority": 820,
      "when": {
        "regex": "^(?<store>[\\p{L}\\p{N}ぁ-んァ-ヶ一-龠々・]{1,12})\\s*(?<start>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)\\s*-\\s*(?<end>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)$"
      },
      "then": {
        "labels_add": [
          "store_time_range"
        ],
        "set": {
          "entities.help_store": "{store}",
          "entities.start_time": {
            "normalize_time": "{start}"
          },
          "entities.end_time": {
            "normalize_time": "{end}"
          },
          "entities.is_until_last": false,
          "entities.segments": [
            {
              "segment_type": "help_store_work",
              "store": "{store}",
              "start_time": {
                "normalize_time": "{start}"
              },
              "end_time": {
                "normalize_time": "{end}"
              }
            }
          ]
        },
        "confidence": 0.92
      }
    },
    {
      "id": "R-470",
      "kind": "rule",
      "name": "番手タグ+時間帯：◯930-1700（タグ付与目的）",
      "priority": 810,
      "when": {
        "regex": "^(?<symbol>(?:\\u3007|\\u25CB|\\u25EF|O|o|\\u25B3|\\u25B2|\\u2715|\\u00D7|\\u2717|\\u2716\\uFE0F|X|x))\\s*(?<start>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)\\s*-\\s*(?<end>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)$"
      },
      "then": {
        "labels_add": [
          "time_range",
          "shift_tagged_time_range"
        ],
        "set": {
          "entities.shift_tags": [
            {
              "map_by_alias": {
                "source": "{symbol}",
                "mapping_ref": "definitions.tokens.shift_symbol_map",
                "return": "shift_type"
              }
            }
          ],
          "entities.start_time": {
            "normalize_time": "{start}"
          },
          "entities.end_time": {
            "normalize_time": "{end}"
          },
          "entities.is_until_last": false
        },
        "confidence": 0.9
      }
    },
    {
      "id": "R-415",
      "kind": "rule",
      "name": "店舗+番手+退勤時刻：川崎◯-17:00（正規化後）",
      "priority": 780,
      "when": {
        "regex": "^(?<store>[\\\\p{L}\\\\p{N}\\u3041-\\u3093\\u30A1-\\u30F6\\u4E00-\\u9FA0\\u3005\\u30FB]{1,12})(?<symbol>(?:\\u3007|\\u25CB|\\u25EF|O|o|\\u25B3|\\u25B2|\\u2715|\\u00D7|\\u2717|\\u2716\\uFE0F|X|x))\\s*-\\s*(?<end>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)$"
      },
      "then": {
        "labels_add": [
          "help",
          "shift_symbol",
          "partial_time"
        ],
        "set": {
          "entities.help_store": "{store}",
          "entities.shift_type": {
            "map_by_alias": {
              "source": "{symbol}",
              "mapping_ref": "definitions.tokens.shift_symbol_map"
            }
          },
          "entities.end_time": {
            "normalize_time": "{end}"
          },
          "entities.is_until_last": false
        },
        "confidence": 0.9
      }
    },
    {
      "id": "R-420",
      "kind": "rule",
      "name": "番手+退勤時刻：◯-18:00 / ✖️-1700（正規化後）",
      "priority": 750,
      "when": {
        "regex": "^(?<symbol>(?:\\u3007|\\u25CB|\\u25EF|O|o|\\u25B3|\\u25B2|\\u2715|\\u00D7|\\u2717|\\u2716\\uFE0F|X|x))\\s*-\\s*(?<end>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)$"
      },
      "then": {
        "labels_add": [
          "shift_symbol",
          "partial_time"
        ],
        "set": {
          "entities.shift_type": {
            "map_by_alias": {
              "source": "{symbol}",
              "mapping_ref": "definitions.tokens.shift_symbol_map"
            }
          },
          "entities.end_time": {
            "normalize_time": "{end}"
          },
          "entities.is_until_last": false
        },
        "confidence": 0.88
      }
    },
    {
      "id": "R-460",
      "kind": "rule",
      "name": "通し出勤：◯-✖️（早番開始〜遅番終了）",
      "priority": 770,
      "when": {
        "regex": "^(?<sym1>〇|○|◯|O|o)\\s*-\\s*(?<sym2>✕|×|✗|X|x)$"
      },
      "then": {
        "labels_add": [
          "through_shift",
          "shift_symbol"
        ],
        "set": {
          "entities.shift_tags": [
            "through"
          ],
          "entities.shift_type": null,
          "entities.is_until_last": false
        },
        "confidence": 0.9
      }
    },
    {
      "id": "R-400",
      "kind": "rule",
      "name": "時間帯：11:00-18:00 / 1100-1800 / 11-18 / 11-18:00",
      "priority": 700,
      "when": {
        "regex": "^(?<start>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)\\s*-\\s*(?<end>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)$"
      },
      "then": {
        "labels_add": [
          "time_range"
        ],
        "set": {
          "entities.start_time": {
            "normalize_time": "{start}"
          },
          "entities.end_time": {
            "normalize_time": "{end}"
          },
          "entities.is_until_last": false
        },
        "confidence": 0.9
      }
    },
    {
      "id": "R-410",
      "kind": "rule",
      "name": "ラスト：11:00- / 11-（終わり時刻なし）",
      "priority": 690,
      "when": {
        "regex": "^(?<start>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)\\s*-\\s*$"
      },
      "then": {
        "labels_add": [
          "until_last"
        ],
        "set": {
          "entities.start_time": {
            "normalize_time": "{start}"
          },
          "entities.end_time": null,
          "entities.is_until_last": true
        },
        "confidence": 0.85
      }
    },
    {
      "id": "R-500",
      "kind": "rule",
      "name": "番手記号単体：〇 / △ / ✕",
      "priority": 600,
      "when": {
        "regex": "^(?<symbol>(?:\\u3007|\\u25CB|\\u25EF|O|o|\\u25B3|\\u25B2|\\u2715|\\u00D7|\\u2717|\\u2716\\uFE0F|X|x))$"
      },
      "then": {
        "labels_add": [
          "shift_symbol"
        ],
        "set": {
          "entities.shift_type": {
            "map_by_alias": {
              "source": "{symbol}",
              "mapping_ref": "definitions.tokens.shift_symbol_map"
            }
          },
          "entities.is_until_last": false
        },
        "confidence": 0.85
      }
    },
    {
      "id": "R-900",
      "kind": "fallback",
      "name": "解釈不能は休み扱い（不明記号は休みカウント）",
      "priority": 100,
      "when": {
        "always": true
      },
      "then": {
        "labels_add": [
          "fallback"
        ],
        "set": {
          "entities.leave_type": "off_day",
          "entities.is_until_last": false
        },
        "errors_add": [
          {
            "code": "UNPARSEABLE",
            "message": "ルールに一致せず解釈不能のため休み扱い"
          }
        ],
        "confidence": 0.4
      }
    },
    {
      "id": "R-471",
      "kind": "rule",
      "name": "???????+???????????: ?930-1700",
      "priority": 808,
      "when": {
        "regex": "^(?<symbol>(?:\\u3007|\\u25CB|\\u25EF|O|o|\\u25B3|\\u25B2|\\u2715|\\u00D7|\\u2717|\\u2716\\uFE0F|X|x))(?<start>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)\\s*-\\s*(?<end>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)$"
      },
      "then": {
        "labels_add": [
          "time_range",
          "shift_tagged_time_range"
        ],
        "set": {
          "entities.shift_tags": [
            {
              "map_by_alias": {
                "source": "{symbol}",
                "mapping_ref": "definitions.tokens.shift_symbol_map",
                "return": "shift_type"
              }
            }
          ],
          "entities.start_time": {
            "normalize_time": "{start}"
          },
          "entities.end_time": {
            "normalize_time": "{end}"
          },
          "entities.is_until_last": false
        },
        "confidence": 0.9
      }
    },
    {
      "id": "R-472",
      "kind": "rule",
      "name": "?????+???????????: 11-20:30? / 10:30-20?",
      "priority": 705,
      "when": {
        "regex": "^(?<start>(?:[01]?\\\\d|2[0-3])(?::?[0-5]\\\\d)?)\\\\s*[-~\\u301c\\uff5e]\\\\s*(?<end>(?:[01]?\\\\d|2[0-3])(?::?[0-5]\\\\d)?)\\\\s*(?<symbol>(?:\\u3007|\\u25CB|\\u25EF|O|o|\\u25B3|\\u25B2|\\u2715|\\u00D7|\\u2717|\\u2716\\uFE0F|X|x))$"
      },
      "then": {
        "labels_add": [
          "time_range",
          "shift_tagged_time_range"
        ],
        "set": {
          "entities.shift_tags": [
            {
              "map_by_alias": {
                "source": "{symbol}",
                "mapping_ref": "definitions.tokens.shift_symbol_map",
                "return": "shift_type"
              }
            }
          ],
          "entities.start_time": {
            "normalize_time": "{start}"
          },
          "entities.end_time": {
            "normalize_time": "{end}"
          },
          "entities.is_until_last": false
        },
        "confidence": 0.9
      }
    }
  ],
  "postprocess": {
    "finalize": [
      {
        "name": "default_store_assignment",
        "description": "店舗表記が無い場合は所属店舗（context.home_store / context.home_store_cd）を勤務先として確定する",
        "rules": [
          {
            "when": {
              "all_of": [
                {
                  "entities.help_store": {
                    "is_null": true
                  }
                },
                {
                  "entities.home_store": {
                    "is_null": true
                  }
                },
                {
                  "any_of": [
                    {
                      "labels_contains": "partial_time"
                    },
                    {
                      "labels_contains": "time_range"
                    },
                    {
                      "labels_contains": "until_last"
                    },
                    {
                      "labels_contains": "shift_symbol"
                    },
                    {
                      "labels_contains": "two_segment_mixed"
                    },
                    {
                      "labels_contains": "through_shift"
                    },
                    {
                      "labels_contains": "shift_tagged_time_range"
                    }
                  ]
                }
              ]
            },
            "then": {
              "set": {
                "entities.home_store": "{context.home_store|null}",
                "entities.home_store_cd": "{context.home_store_cd|null}"
              },
              "confidence_multiply": 1.05
            }
          },
          {
            "when": {
              "all_of": [
                {
                  "any_of": [
                    {
                      "labels_contains": "partial_time"
                    },
                    {
                      "labels_contains": "two_segment_mixed"
                    },
                    {
                      "labels_contains": "through_shift"
                    },
                    {
                      "labels_contains": "shift_tagged_time_range"
                    }
                  ]
                },
                {
                  "entities.home_store": {
                    "is_null": true
                  }
                },
                {
                  "entities.home_store_cd": {
                    "is_null": true
                  }
                }
              ]
            },
            "then": {
              "errors_add": [
                {
                  "code": "HOME_STORE_MISSING",
                  "message": "店舗表記なしのため所属店舗をcontextで指定してください（home_storeまたはhome_store_cdが必要）"
                }
              ],
              "confidence_multiply": 0.85
            }
          }
        ]
      },
      {
        "name": "parse_multi_segment_store_time_ranges",
        "description": "連結された店舗+時間の繰り返しを抽出して segments に変換（例：川崎11:00-12:00柏13:00-1800）",
        "rules": [
          {
            "when": {
              "labels_contains": "multi_segment_compact"
            },
            "then": {
              "set": {
                "entities.segments": {
                  "extract_repeated": {
                    "pattern": "(?<store>[\\p{L}\\p{N}ぁ-んァ-ヶ一-龠々・]{1,12})\\s*(?<start>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)\\s*-\\s*(?<end>(?:[01]?\\d|2[0-3])(?::?[0-5]\\d)?)",
                    "normalize_time_fields": [
                      "start",
                      "end"
                    ],
                    "to_items": {
                      "segment_type": "help_store_work",
                      "store": "{store}",
                      "start_time": "{start}",
                      "end_time": "{end}"
                    }
                  }
                },
                "entities.start_time": "{entities.segments[0].start_time}",
                "entities.end_time": "{entities.segments[last].end_time}",
                "entities.is_until_last": false
              },
              "labels_add": [
                "composite_move",
                "help"
              ],
              "confidence_multiply": 1.02
            }
          }
        ]
      },
      {
        "name": "build_segments_for_two_segment_mixed",
        "description": "two_segment_mixed を segments に展開（前半は所属店舗、後半は指定店舗）",
        "rules": [
          {
            "when": {
              "labels_contains": "two_segment_mixed"
            },
            "then": {
              "set": {
                "entities.segments": [
                  {
                    "segment_type": "home_store_work",
                    "store": "{entities.home_store|null}",
                    "start_time": {
                      "normalize_time": "{start1}"
                    },
                    "end_time": {
                      "normalize_time": "{end1}"
                    }
                  },
                  {
                    "segment_type": "help_store_work",
                    "store": "{entities.help_store}",
                    "start_time": {
                      "normalize_time": "{start2}"
                    },
                    "end_time": {
                      "normalize_time": "{end2}"
                    }
                  }
                ],
                "entities.start_time": {
                  "normalize_time": "{start1}"
                },
                "entities.end_time": {
                  "normalize_time": "{end2}"
                },
                "entities.is_until_last": false
              },
              "labels_add": [
                "composite_move",
                "help"
              ],
              "confidence_multiply": 1.01
            }
          },
          {
            "when": {
              "all_of": [
                {
                  "labels_contains": "two_segment_mixed"
                },
                {
                  "entities.home_store": {
                    "is_null": true
                  }
                }
              ]
            },
            "then": {
              "errors_add": [
                {
                  "code": "HOME_STORE_MISSING",
                  "message": "前半が店舗なしのため所属店舗（context.home_store等）が必要です"
                }
              ],
              "confidence_multiply": 0.85
            }
          }
        ]
      },
      {
        "name": "store_resolution",
        "description": "store_master.jsonを参照して home_store/help_store を略称へ正規化し、店舗CDを付与する",
        "store_master_ref": "EXTERNAL:store_master.json",
        "helpers": {
          "normalize_key": {
            "steps": [
              "unicode_nfkc",
              "trim",
              "collapse_spaces",
              {
                "remove": [
                  "店"
                ]
              }
            ]
          }
        },
        "rules": [
          {
            "when": {
              "entities.help_store": {
                "not_null": true
              }
            },
            "then": {
              "set": {
                "entities.help_store": {
                  "resolve_store_abbrev": {
                    "value": "{entities.help_store}",
                    "stores_ref": "EXTERNAL:store_master.json/stores",
                    "match_order": [
                      "abbrev_exact",
                      "alias_exact",
                      "abbrev_normalized",
                      "alias_normalized"
                    ]
                  }
                },
                "entities.help_store_cd": {
                  "resolve_store_cd_full": {
                    "value": "{entities.help_store}",
                    "stores_ref": "EXTERNAL:store_master.json/stores",
                    "match_order": [
                      "abbrev_exact",
                      "alias_exact",
                      "abbrev_normalized",
                      "alias_normalized"
                    ]
                  }
                }
              }
            }
          },
          {
            "when": {
              "entities.home_store": {
                "not_null": true
              }
            },
            "then": {
              "set": {
                "entities.home_store": {
                  "resolve_store_abbrev": {
                    "value": "{entities.home_store}",
                    "stores_ref": "EXTERNAL:store_master.json/stores",
                    "match_order": [
                      "abbrev_exact",
                      "alias_exact",
                      "abbrev_normalized",
                      "alias_normalized"
                    ]
                  }
                },
                "entities.home_store_cd": {
                  "resolve_store_cd_full": {
                    "value": "{entities.home_store}",
                    "stores_ref": "EXTERNAL:store_master.json/stores",
                    "match_order": [
                      "abbrev_exact",
                      "alias_exact",
                      "abbrev_normalized",
                      "alias_normalized"
                    ]
                  }
                }
              }
            }
          },
          {
            "when": {
              "any_of": [
                {
                  "entities.help_store": {
                    "not_null": true
                  },
                  "entities.help_store_cd": {
                    "is_null": true
                  }
                },
                {
                  "entities.home_store": {
                    "not_null": true
                  },
                  "entities.home_store_cd": {
                    "is_null": true
                  }
                }
              ]
            },
            "then": {
              "errors_add": [
                {
                  "code": "STORE_NOT_FOUND",
                  "message": "store_masterに存在しない略称/別名のため店舗CDを確定できません（aliases追記 or 入力修正）"
                }
              ],
              "confidence_multiply": 0.9
            }
          }
        ]
      },
      {
        "name": "shift_time_completion_from_external_master",
        "description": "番手+片側時刻（◯-18:00 等）の場合、外部の店舗別出勤時間マスタから start_time を補完する",
        "shift_time_master_ref": "EXTERNAL:shift_time_master.json",
        "rules": [
          {
            "when": {
              "all_of": [
                {
                  "labels_contains": "partial_time"
                },
                {
                  "entities.shift_type": {
                    "not_null": true
                  }
                },
                {
                  "entities.start_time": {
                    "is_null": true
                  }
                },
                {
                  "any_of": [
                    {
                      "entities.help_store_cd": {
                        "not_null": true
                      }
                    },
                    {
                      "entities.home_store_cd": {
                        "not_null": true
                      }
                    }
                  ]
                }
              ]
            },
            "then": {
              "set": {
                "entities.start_time": {
                  "lookup_shift_start": {
                    "store_cd_full_prefer": [
                      "{entities.help_store_cd}",
                      "{entities.home_store_cd}"
                    ],
                    "shift_type": "{entities.shift_type}",
                    "master_ref": "EXTERNAL:shift_time_master.json/stores"
                  }
                },
                "entities.segments": [
                  {
                    "segment_type": "resolved_work",
                    "store": "{entities.help_store|null}",
                    "start_time": "{entities.start_time}",
                    "end_time": "{entities.end_time}"
                  }
                ]
              },
              "confidence_multiply": 1.05
            }
          },
          {
            "when": {
              "all_of": [
                {
                  "labels_contains": "partial_time"
                },
                {
                  "entities.start_time": {
                    "is_null": true
                  }
                }
              ]
            },
            "then": {
              "errors_add": [
                {
                  "code": "SHIFT_START_TIME_UNRESOLVED",
                  "message": "番手+退勤時刻は解釈できたが、店舗別出勤時間マスタ参照に必要な店舗CDが無いため start_time を補完できません"
                }
              ],
              "confidence_multiply": 0.9
            }
          }
        ]
      },
      {
        "name": "resolve_through_shift_times",
        "description": "通し出勤（◯-✖️）は、外部マスタから early.start と late.end を引いて start/end を確定する",
        "shift_time_master_ref": "EXTERNAL:shift_time_master.json",
        "rules": [
          {
            "when": {
              "all_of": [
                {
                  "labels_contains": "through_shift"
                },
                {
                  "entities.start_time": {
                    "is_null": true
                  }
                },
                {
                  "entities.end_time": {
                    "is_null": true
                  }
                },
                {
                  "entities.home_store_cd": {
                    "not_null": true
                  }
                }
              ]
            },
            "then": {
              "set": {
                "entities.start_time": {
                  "lookup_shift_start": {
                    "store_cd_full": "{entities.home_store_cd}",
                    "shift_type": "early",
                    "master_ref": "EXTERNAL:shift_time_master.json/stores"
                  }
                },
                "entities.end_time": {
                  "lookup_shift_end": {
                    "store_cd_full": "{entities.home_store_cd}",
                    "shift_type": "late",
                    "master_ref": "EXTERNAL:shift_time_master.json/stores"
                  }
                },
                "entities.segments": [
                  {
                    "segment_type": "home_store_work",
                    "store": "{entities.home_store|null}",
                    "start_time": "{entities.start_time}",
                    "end_time": "{entities.end_time}"
                  }
                ],
                "entities.is_until_last": false
              },
              "confidence_multiply": 1.05
            }
          },
          {
            "when": {
              "all_of": [
                {
                  "labels_contains": "through_shift"
                },
                {
                  "entities.home_store_cd": {
                    "is_null": true
                  }
                }
              ]
            },
            "then": {
              "errors_add": [
                {
                  "code": "HOME_STORE_CD_MISSING",
                  "message": "通し出勤（◯-✖️）は所属店舗CDが必要です（context.home_store_cd 推奨）"
                }
              ],
              "confidence_multiply": 0.85
            }
          }
        ]
      },
      {
        "name": "normalized_text_builder",
        "description": "entitiesから normalized_text を組み立てる",
        "rules": [
          {
            "when": {
              "entities.leave_type": "requested_off"
            },
            "then": {
              "normalized_text": "/"
            }
          },
          {
            "when": {
              "entities.leave_type": "paid_leave"
            },
            "then": {
              "normalized_text": "有給"
            }
          },
          {
            "when": {
              "entities.leave_type": "off_day"
            },
            "then": {
              "normalized_text": "公休"
            }
          },
          {
            "when": {
              "labels_contains": "through_shift"
            },
            "then": {
              "normalized_text": "{entities.start_time}-{entities.end_time}（通し）"
            }
          },
          {
            "when": {
              "labels_contains": "partial_time"
            },
            "then": {
              "normalized_text": "{entities.start_time}-{entities.end_time}"
            }
          },
          {
            "when": {
              "labels_contains": "time_range"
            },
            "then": {
              "normalized_text": "{entities.start_time}-{entities.end_time}"
            }
          },
          {
            "when": {
              "labels_contains": "until_last"
            },
            "then": {
              "normalized_text": "{entities.start_time}-LAST"
            }
          }
        ]
      }
    ]
  },
  "quality": {
    "validation": {
      "required_fields": [
        "entities",
        "confidence",
        "errors",
        "labels"
      ],
      "error_on_missing": true
    },
    "confidence_policy": {
      "high_threshold": 0.85,
      "medium_threshold": 0.6,
      "low_threshold": 0.4
    }
  }
}